{
    "notifications": {
        "timeout_low": 4000,
        "timeout_normal": 6000,
        "timeout_critical": 0,

        "dismiss_on_unhover": false,
        "hold_on_hover": true,
        "position_h": "right",
        "position_v": "top"
    },
    "night_light": {
        "save_on_shutdown": true
    },
    "wallpaper": {
        "positioning": "cover",
        "color_mode": "darken",
        "splash": true
    },
    "screen_recording": {
        "include_audio": true
    },
    "idle": {
        "lock_timeout": 2500,
        "ignore_dbus_inhibit": false,
        "ignore_systemd_inhibit": false,
        "ignore_wayland_inhibit": false,
        "inhibit_sleep": 2
    },
    "workspaces": {
        "always_show_id": false,
        "enable_helper": true,
        "hide_if_single": true,
        "show_id_on_hover": true
    },
    "aliases": {
        "terminal": "kitty",
        "media": "vibe",
        "file_manager": "nautilus"
    },
    "clock": {
        "date_format": "%A %d, %H:%M"
    },
    "misc": {
        "play_bell_on_volume_change": true
    }
}
